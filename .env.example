# Telegram
# Pegue no @BotFather. Nunca compartilhe este token.
TELEGRAM_BOT_TOKEN=cole_aqui_o_token_novo_do_botfather

# Pegue em https://api.telegram.org/botSEU_TOKEN/getUpdates depois de mandar /start para o bot.
TELEGRAM_CHAT_ID=cole_aqui_seu_chat_id

# SerpApi
# Pegue em https://serpapi.com/manage-api-key
SERPAPI_KEY=cole_aqui_sua_chave_serpapi

# Config geral
CURRENCY=BRL
LANGUAGE=pt-BR
COUNTRY=br
CHECK_EVERY_MINUTES=60
REQUEST_SLEEP_SECONDS=2
SEND_STARTUP_MESSAGE=true
DEEP_SEARCH=false

# Datas da viagem: o bot checa todas as datas desse intervalo
START_DATE=2027-02-01
END_DATE=2027-03-31
DATE_STEP_DAYS=3

# Duracoes para ida e volta em dias. Ex.: 12,14,16
ROUND_TRIP_DURATIONS=12,14,16

# Alvos de preco em BRL
ONEWAY_TARGET_BRL=1800
ROUNDTRIP_TARGET_BRL=3600

# Para teste, deixe 3 ou 5. Para rodar completo, coloque 0.
MAX_CHECKS_PER_RUN=5

# Banco local usado para evitar alertas repetidos
DB_PATH=alerts_sent.sqlite3
ROUTES_PATH=routes.json
