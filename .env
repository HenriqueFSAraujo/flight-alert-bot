LANGUAGE=pt-BR
COUNTRY=br
CHECK_EVERY_MINUTES=60
REQUEST_SLEEP_SECONDS=2
SEND_STARTUP_MESSAGE=true
DEEP_SEARCH=false

# Datas da viagem: o bot checa todas as datas desse intervalo
